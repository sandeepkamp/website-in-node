<%- include('../partials/header') %>

<h1 class="text-3xl font-bold">Contact Us</h1>

<form action="/contact" method="POST" class="mt-4">
    <input type="text" name="name" placeholder="Name" class="block mb-2 p-2 border w-full" required>
    <input type="email" name="email" placeholder="Email" class="block mb-2 p-2 border w-full" required>
    <textarea name="message" placeholder="Message" class="block mb-2 p-2 border w-full" required></textarea>
    
    <button class="bg-blue-500 text-white px-4 py-2">Submit</button>
</form>

<%- include('../partials/footer') %>